{
  "name": "wysiwyghtml",
  "version": "1.0.0",
  "description": "WYSIWYG HTML Editor built with Electron and CKEditor 5",
  "main": "main.js",
  "scripts": {
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron . --no-sandbox",
    "dev": "npm run build:renderer && electron . --no-sandbox",
    "build": "npm run build:renderer && electron-builder",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "wysiwyg",
    "ckeditor"
  ],
  "author": {
    "name": "medmor",
    "email": "medmor@example.com"
  },
  "license": "ISC",
  "homepage": "https://github.com/medmor/WYSIWYGHTML",
  "devDependencies": {
    "ckeditor5": "^47.6.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.wysiwyghtml.editor",
    "productName": "WYSIWYG HTML Editor",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "TextEditor"
    }
  }
}
