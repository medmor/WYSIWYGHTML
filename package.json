{
  "name": "wysiwyghtml",
  "version": "1.0.0",
  "description": "WYSIWYG HTML Editor built with Electron and CKEditor 5",
  "main": "main.js",
  "scripts": {
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron . --no-sandbox",
    "dev": "npm run build:renderer && electron . --no-sandbox",
    "build": "npm run build:renderer && electron-builder",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "wysiwyg",
    "ckeditor"
  ],
  "author": {
    "name": "medmor",
    "email": "medmor@example.com"
  },
  "license": "ISC",
  "homepage": "https://github.com/medmor/WYSIWYGHTML",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "ckeditor5": "^47.6.1",
    "daisyui": "^5.5.19",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.wysiwyghtml.editor",
    "productName": "WYSIWYG HTML Editor",
    "files": [
      "main.js",
      "store.js",
      "index.html",
      "preview.html",
      "print.html",
      "src/**/*",
      "dist/renderer.js",
      "dist/renderer.js.map",
      "dist/assets/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "TextEditor"
    }
  },
  "dependencies": {
    "pagedjs": "^0.4.3"
  }
}
